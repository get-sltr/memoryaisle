# MemoryAisle Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to version control

# ==============================================
# REQUIRED: Supabase Configuration
# ==============================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# ==============================================
# OPTIONAL: Picovoice Wake Word Detection
# ==============================================
# Get your key at: https://console.picovoice.ai/
# Required for "Hey Mira" wake word functionality
PICOVOICE_ACCESS_KEY=your_picovoice_access_key_here

# ==============================================
# SERVER-SIDE ONLY (Supabase Edge Functions)
# ==============================================
# These are configured in Supabase Dashboard > Edge Functions > Secrets
# Do NOT add these to your local .env file
#
# OPENAI_API_KEY - For Mira AI features
# SUPABASE_SERVICE_ROLE_KEY - For admin operations
