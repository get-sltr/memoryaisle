# MemoryAisle Environment Variables
# Copy this file to .env.local and fill in the values

# Picovoice - Wake word detection ("Hey Mira")
# Get your key at: https://console.picovoice.ai/
PICOVOICE_ACCESS_KEY=your_picovoice_access_key_here

# Supabase (configured in app, but documented here)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_anon_key_here

# OpenAI (configured in Supabase Edge Functions secrets)
# OPENAI_API_KEY=your_openai_api_key_here
