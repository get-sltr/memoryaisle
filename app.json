{
  "expo": {
    "name": "MemoryAisle",
    "slug": "memoryaisle",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "memoryaisle",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F9FB"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "58",
      "bundleIdentifier": "com.memoryaisle.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch"
        ],
        "NSCameraUsageDescription": "We use your camera to scan receipts and learn your shopping patterns.",
        "NSMicrophoneUsageDescription": "Mira uses your microphone to listen for 'Hey Mira' and to hear items you want to add to your list.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8F9FB"
      },
      "package": "com.memoryaisle.app",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      "react-native-iap",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "MemoryAisle needs background location access to alert you when you arrive at a saved grocery store so you don't forget your shopping list.",
          "locationAlwaysPermission": "MemoryAisle needs background location access to alert you when you arrive at a saved grocery store so you don't forget your shopping list.",
          "locationWhenInUsePermission": "MemoryAisle uses your location to help you save the grocery stores you are currently visiting.",
          "isIosBackgroundLocationEnabled": false,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "minSdkVersion": 24
          }
        }
      ],
      "react-native-wakeword",
      "./plugins/withWakeWordModel"
    ],
    "extra": {
      "router": {},
      "supabaseUrl": "",
      "supabaseAnonKey": "",
      "davoiceLicenseKey": "",
      "eas": {
        "projectId": "143688ac-a91a-449d-a4a8-dd6f9663a7a8"
      }
    },
    "owner": "memoryaisle"
  }
}
