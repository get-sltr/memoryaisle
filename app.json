{
  "expo": {
    "name": "MemoryAisle",
    "slug": "memoryaisle",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "memoryaisle",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F9FB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.memoryaisle.app", 
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We use your location to show your grocery list when you arrive at a store.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We use your location to notify you when you arrive at a store so you never forget your list.",
        "NSCameraUsageDescription": "We use your camera to scan receipts and learn your shopping patterns.",
        "NSMicrophoneUsageDescription": "Mira uses your microphone to hear what items you want to add to your list.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8F9FB"
      },
      "package": "com.memoryaisle.app",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "@sentry/react-native/expo",
        {
          "organization": "sltr",
          "project": "memoryaisle"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Memoryaisle to use your location to auto-show your list at stores.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "minSdkVersion": 24
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "143688ac-a91a-449d-a4a8-dd6f9663a7a8"
      },
      "router": {}
    },
    "owner": "memoryaisle"
  }
}
